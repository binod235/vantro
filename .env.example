# ── Database — Railway PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the Next.js frontend. Used to construct the password reset link
# in emails. Change to your Cloudflare Pages URL when deploying.
FRONTEND_URL=http://localhost:3001

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@vantro.co.uk

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── HMRC — always use sandbox URL during development, never production ─────────
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_SANDBOX_URL=https://test-api.service.hmrc.gov.uk
HMRC_PRODUCTION_URL=https://api.service.hmrc.gov.uk

# ── Next.js frontend (web/.env.local) — NEXT_PUBLIC_ vars are bundled client-side
NEXT_PUBLIC_API_URL=http://localhost:3000
