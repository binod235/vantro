      "name": "Register Owner",
      "url": "http://localhost:3000/api/auth/sign-up/email",
      "method": "POST",
      "sortNum": 1,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"owner@vantro-test.com\",\n  \"password\": \"TestPassword1!\",\n  \"name\": \"Jane Smith\",\n  \"role\": \"OWNER\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
      ],
      "docs": "Creates a company owner account. Sets role=OWNER so the user can manage company, customers, jobs, and financials."
    },
    {
      "_id": "auth-register-engineer",
      "colId": "vantro-auth",
      "containerId": "",
