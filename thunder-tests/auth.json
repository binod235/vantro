      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"engineer@vantro-test.com\",\n  \"password\": \"TestPassword1!\",\n  \"name\": \"Bob Engineer\",\n  \"role\": \"ENGINEER\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
