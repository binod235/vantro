    {
      "_id": "auth-sign-in",
      "colId": "vantro-auth",
      "containerId": "",
      "name": "Sign In",
      "url": "http://localhost:3000/api/auth/sign-in/email",
      "method": "POST",
      "sortNum": 3,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"owner@vantro-test.com\",\n  \"password\": \"TestPassword1!\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" },
        { "type": "res-body", "custom": "$.user.email", "action": "equal", "value": "owner@vantro-test.com" }
      ],
      "docs": "Signs in and receives a session cookie (better-auth.session_token). The cookie is HttpOnly and will be sent automatically on subsequent requests."
    },
    {
      "_id": "auth-get-session",
      "colId": "vantro-auth",
      "containerId": "",
      "name": "Get Session",
      "url": "http://localhost:3000/api/auth/get-session",
      "method": "GET",
      "sortNum": 4,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [],
      "params": [],
      "body": { "type": "none", "raw": "" },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" },
        { "type": "res-body", "custom": "$.user.role", "action": "equal", "value": "OWNER" }
      ],
      "docs": "Returns the current user and session. Requires the session cookie set by Sign In. Use this to confirm the session is active and check the user's role and companyId."
    },
    {
      "_id": "auth-sign-out",
      "colId": "vantro-auth",
      "containerId": "",
      "name": "Sign Out",
      "url": "http://localhost:3000/api/auth/sign-out",
      "method": "POST",
      "sortNum": 5,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [],
      "params": [],
      "body": { "type": "none", "raw": "" },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
      ],
      "docs": "Invalidates the session in the database immediately. The cookie is cleared. Any subsequent request with the old cookie will be rejected — this is why sessions are better than JWT for this use case."
    },
    {
      "_id": "auth-forgot-password",
      "colId": "vantro-auth",
      "containerId": "",
      "name": "Forgot Password — Request Reset Email",
      "url": "http://localhost:3000/api/auth/forget-password",
      "method": "POST",
      "sortNum": 6,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"owner@vantro-test.com\",\n  \"redirectTo\": \"http://localhost:3001/reset-password\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
      ],
      "docs": "Triggers a password reset email via Resend. Better Auth generates a secure token, stores it in the verification table with a 1-hour expiry, and sends the reset link to the user's email. The link points to FRONTEND_URL/reset-password?token=TOKEN. Always returns 200 even if the email does not exist (prevents user enumeration)."
    },
    {
      "_id": "auth-reset-password",
      "colId": "vantro-auth",
      "containerId": "",
      "name": "Reset Password — Submit New Password",
      "url": "http://localhost:3000/api/auth/reset-password",
      "method": "POST",
      "sortNum": 7,
      "created": "2026-05-26T00:00:00.000Z",
      "modified": "2026-05-26T00:00:00.000Z",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"newPassword\": \"NewPassword1!\",\n  \"token\": \"PASTE_TOKEN_FROM_RESET_EMAIL_HERE\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
      ],
      "docs": "Completes the password reset. Replace the token value with the one from the reset email URL (?token=...). The token is deleted from the database on use so it cannot be reused. Returns 400 if the token has expired or is invalid."
    }
  ]
}
