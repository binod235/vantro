generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ENGINEER
}

enum JobStatus {
  QUOTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  INVOICED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  LOCKED
}

enum EnquirySource {
  PHONE
  EMAIL
  WEBSITE
  REFERRAL
  WALKIN
  OTHER
}

enum EnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED
  DONE
  REJECTED
}

enum IntakeMethod {
  MANUAL
  EMAIL
  DIRECT_LINK
}

enum BillingRate {
  STANDARD
  OVERTIME
  DOUBLE_TIME
  UNPAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PART_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceType {
  STANDARD
  DEPOSIT
  PROGRESS
  FINAL
}

enum InvoiceSourceType {
  MANUAL
  JOB
  QUOTE
}

enum QuoteInvoiceMode {
  ENTIRE_QUOTE
  SELECTED_LINE_ITEMS
  PERCENTAGE
  FIXED_AMOUNT
}

enum VatType {
  STANDARD
  REVERSE_CHARGE
  EXEMPT
  ZERO_RATED
}

enum QuoteStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  INVOICED
  EXPIRED
  CANCELLED
}

enum GasCertType {
  CP12
  BOILER_SERVICE
  GAS_WARNING
  INSTALLATION
}

enum GasCertStatus {
  DRAFT
  COMPLETE
  SENT
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

enum TodoStatus {
  OPEN
  DONE
}

// ─── Better Auth tables (camelCase as required by Better Auth) ───────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role              Role      @default(ENGINEER)
  companyId         String?
  invite_token      String?   @unique
  invite_expires_at DateTime?
  calendar_colour   String?
  gas_safe_number   String?
  corgi_number      String?
  qualification     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company              Company?               @relation(fields: [companyId], references: [id])
  sessions             Session[]
  accounts             Account[]
  timesheets            Timesheet[]
  approved_timesheets   Timesheet[] @relation("TimesheetApprover")
  gasCertificates       GasSafetyCertificate[]
  assignedJobs         Job[]                  @relation("EngineerJobs")
  assigned_enquiries   Enquiry[]              @relation("EnquiryAssignee")
  created_todos        Todo[]                 @relation("TodoCreator")
  assigned_todos       Todo[]                 @relation("TodoAssignee")
  completed_todos      Todo[]                 @relation("TodoCompleter")
  activeTimers          ActiveTimer[]
  jobPhotos             JobPhoto[]
  recurringJobTemplates RecurringJob[]
  defaultJobTemplates   JobTemplate[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Application tables ──────────────────────────────────────────────────────

model Company {
  id                     String             @id @default(cuid())
  name                   String
  slug                   String?            @unique
  subscription_status    SubscriptionStatus @default(TRIAL)
  trial_ends_at          DateTime
  stripe_customer_id     String?
  stripe_subscription_id String?
  payment_failed                Boolean   @default(false)
  payment_failed_at             DateTime?
  stripe_cancel_at_period_end   Boolean   @default(false)
  stripe_current_period_end     DateTime?
  // Stripe Connect (invoice payments)
  stripe_connect_id           String?
  stripe_connect_enabled      Boolean  @default(false)
  stripe_connect_onboarded    Boolean  @default(false)
  pass_fee_to_customer        Boolean  @default(false)
  trial_reminder_4_days_sent_at DateTime?
  trial_reminder_1_day_sent_at  DateTime?
  standard_rate_pence        Int                @default(0)
  overtime_rate_pence        Int                @default(0)
  double_time_rate_pence     Int                @default(0)

  // Business identity
  vat_number          String?
  vat_registered      Boolean  @default(false)
  default_vat_rate    Float    @default(20.0)
  cis_registered           Boolean @default(false)
  cis_number               String?
  cis_accounts_office_ref  String?

  // Logo
  logo_url            String?

  // Invoice settings
  invoice_prefix        String  @default("INV")
  invoice_next_number   Int     @default(1)
  default_payment_terms String? @default("Payment due within 30 days")
  default_invoice_notes String?

  quote_prefix      String  @default("QUO")
  quote_next_number Int     @default(1)
  quote_expiry_days Int     @default(30)

  gas_cert_next_number Int @default(1)

  po_prefix      String @default("PO")
  po_next_number Int    @default(1)

 // Invoice design / branding
  invoice_template          String  @default("MODERN")
  invoice_accent_colour     String  @default("#1d4ed8")
  invoice_show_logo         Boolean @default(true)
  invoice_show_reference    Boolean @default(true)
  invoice_show_site_address Boolean @default(true)
  invoice_show_payment_info Boolean @default(true)
 

  // Payment reminder settings
  payment_reminders_enabled Boolean @default(true)
  reminder_days_before      Int     @default(0)
  reminder_days_after_1     Int     @default(7)
  reminder_days_after_2     Int     @default(14)
  reminder_days_after_3     Int     @default(30)

  // CP12 renewal reminder settings
  cp12_reminders_enabled    Boolean @default(true)
  cp12_reminder_days_before Int     @default(30)

  // Appointment reminder settings
  appointment_reminders_enabled Boolean @default(true)
  appointment_reminder_hours    Int     @default(24)
  appointment_reminder_message  String?

  // Bank details
  bank_name           String?
  bank_account_name   String?
  bank_sort_code      String?
  bank_account_number String?

  // Business address
  address_line1 String?
  address_line2 String?
  city          String?
  county        String?
  postcode      String?
  phone         String?
  website       String?

  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt

  users            User[]
  customers        Customer[]
  jobs             Job[]
  quotes           Quote[]
  invoices         Invoice[]
  invoicePayments  InvoicePayment[]
  suppliers        Supplier[]
  subcontractors          Subcontractor[]
  subcontractorPayments   SubcontractorPayment[]
  cisSufferedDeductions   CisSufferedDeduction[]
  cisMonthlyReturns       CisMonthlyReturn[]
  cisAuditLogs            CisAuditLog[]
  enquiries             Enquiry[]
  timesheets       Timesheet[]
  todos            Todo[]
  gasCertificates  GasSafetyCertificate[]
  activeTimers     ActiveTimer[]
  jobPhotos        JobPhoto[]
  recurringJobs    RecurringJob[]
  priceListItems   PriceListItem[]
  kits             Kit[]
  purchaseOrders   PurchaseOrder[]
  jobStages        JobStage[]
  jobTemplates      JobTemplate[]
  communicationLogs CommunicationLog[]
  jobServiceReports JobServiceReport[]
  jsr_next_number   Int    @default(1)
  jsr_prefix        String @default("JSR")
  jsr_default_terms String?
}

model Customer {
  id            String   @id @default(cuid())
  company_id    String
  name          String
  email         String?
  phone         String?
  address_line1 String?
  address_line2 String?
  city          String?
  postcode      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company           Company                @relation(fields: [company_id], references: [id])
  jobs              Job[]
  quotes            Quote[]
  invoices          Invoice[]
  gasCertificates   GasSafetyCertificate[]
  enquiries         Enquiry[]
  recurringJobs     RecurringJob[]
  communicationLogs CommunicationLog[]
  serviceReports    JobServiceReport[]
}

model Job {
  id               String    @id @default(cuid())
  company_id       String
  customer_id      String
  engineer_id      String?
  title            String
  description      String?
  status           JobStatus @default(QUOTED)
  scheduled_at     DateTime?
  duration_minutes Int?
  schedule_note    String?
  notes            String?
  recurring_job_id String?
  reminder_sent_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  company               Company                @relation(fields: [company_id], references: [id])
  customer              Customer               @relation(fields: [customer_id], references: [id])
  engineer              User?                  @relation("EngineerJobs", fields: [engineer_id], references: [id])
  recurringJob          RecurringJob?          @relation(fields: [recurring_job_id], references: [id], onDelete: SetNull)
  quotes                Quote[]
  invoices              Invoice[]
  subcontractorPayments SubcontractorPayment[]
  gasCertificates       GasSafetyCertificate[]
  timesheets            Timesheet[]
  todos                 Todo[]
  activeTimers          ActiveTimer[]
  photos                JobPhoto[]
  purchaseOrders        PurchaseOrder[]
  stages                JobStage[]
  communicationLogs     CommunicationLog[]
  serviceReports        JobServiceReport[]
}

model Quote {
  id           String      @id @default(cuid())
  company_id   String
  customer_id  String?
  job_id       String?
  quote_number String
  status       QuoteStatus @default(DRAFT)

  line_items   Json     @default("[]")

  subtotal_pence           Int     @default(0)
  vat_amount_pence         Int     @default(0)
  reverse_charge_vat_pence Int     @default(0)
  total_pence              Int     @default(0)
  is_reverse_charge        Boolean @default(false)
  reverse_charge_wording   String?

  issue_date   DateTime?
  expiry_date  DateTime?

  reference    String?
  notes        String?

  amount_pence Int @default(0)

  acceptance_token String?  @unique
  accepted_at      DateTime?
  rejected_at      DateTime?
  rejection_reason String?

  last_sent_at DateTime?
  viewed_at    DateTime?
  view_count   Int       @default(0)

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  company   Company   @relation(fields: [company_id], references: [id])
  customer  Customer? @relation(fields: [customer_id], references: [id])
  job       Job?      @relation(fields: [job_id], references: [id])
  invoices  Invoice[]

  @@unique([company_id, quote_number])
  @@index([company_id])
  @@index([company_id, status])
  @@index([acceptance_token])
}

// Amounts stored in pence (integers) — never floats. See CLAUDE.md.
model Invoice {
  id                       String             @id @default(cuid())
  company_id               String
  customer_id              String
  job_id                   String?
  quote_id                 String?
  invoice_number           String
  status                   InvoiceStatus      @default(DRAFT)
  invoice_type             InvoiceType        @default(STANDARD)
  source_type              InvoiceSourceType?
  quote_invoice_mode       QuoteInvoiceMode?
  quote_percentage         Int?
  fixed_amount_pence       Int?
  line_items               Json               @default("[]")
  subtotal_pence           Int                @default(0)
  vat_amount_pence         Int                @default(0)
  reverse_charge_vat_pence Int                @default(0)
  total_pence              Int                @default(0)
  amount_paid_pence        Int                @default(0)
  amount_due_pence         Int                @default(0)
  due_date                 DateTime?
  issue_date               DateTime           @default(now())
  paid_date                DateTime?
  payment_method           String?
  is_reverse_charge        Boolean            @default(false)
  reverse_charge_wording   String?
  notes                    String?
  last_reminder_sent_at    DateTime?
  reminder_count           Int                @default(0)
  reminders_disabled       Boolean            @default(false)
  viewed_at                DateTime?
  view_count               Int                @default(0)
  // Online payment
  payment_token            String?            @unique
  stripe_payment_intent    String?
  stripe_checkout_session  String?
  paid_online              Boolean            @default(false)
  // Customer payment report
  payment_reported_at      DateTime?
  payment_reported_method  String?
  payment_reported_note    String?
  payment_review_status    String?
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt

  company  Company          @relation(fields: [company_id], references: [id])
  customer Customer         @relation(fields: [customer_id], references: [id])
  job      Job?             @relation(fields: [job_id], references: [id])
  quote    Quote?           @relation(fields: [quote_id], references: [id])
  payments  InvoicePayment[]
  job_stage JobStage?

  @@unique([company_id, invoice_number])
  @@index([company_id])
  @@index([company_id, status])
}

model InvoicePayment {
  id             String   @id @default(cuid())
  company_id     String
  invoice_id     String
  payment_date   DateTime
  amount_pence   Int
  payment_method String?
  reference      String?
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  invoice Invoice @relation(fields: [invoice_id], references: [id])

  @@index([company_id])
  @@index([company_id, invoice_id])
}

model Subcontractor {
  id                  String    @id @default(cuid())
  company_id          String
  name                String

  // Contact
  email               String?
  phone               String?
  address             String?

  // CIS identity
  utr_number          String?   // Unique Taxpayer Reference — mandatory before CIS payment
  ni_number           String?   // National Insurance — sole traders only
  company_reg_number  String?   // Companies House number — limited companies only

  // Subcontractor type: SOLE_TRADER | PARTNERSHIP | COMPANY
  subcontractor_type  String    @default("SOLE_TRADER")

  // CIS status: GROSS=0% | STANDARD=20% | HIGHER=30% (unverified default)
  cis_status          String    @default("HIGHER")
  deduction_rate      Int       @default(30)  // always matches cis_status

  // HMRC verification record
  is_cis_verified     Boolean   @default(false)
  verification_number String?   // returned by HMRC when verified
  verification_date   DateTime? // when verification was done
  verified_by_user_id String?   // who ran the verification

  is_active           Boolean   @default(true)
  notes               String?

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  company  Company                @relation(fields: [company_id], references: [id])
  payments SubcontractorPayment[]

  @@index([company_id])
}

// CIS: deduction applied to labour_amount_pence ONLY — never to materials/VAT/equipment. See CLAUDE.md.
model SubcontractorPayment {
  id               String   @id @default(cuid())
  company_id       String
  job_id           String?
  subcontractor_id String

  // Amounts — CIS deduction on labour ONLY
  gross_amount_pence      Int
  labour_amount_pence     Int
  materials_amount_pence  Int @default(0)
  vat_amount_pence        Int @default(0)
  equipment_hire_pence    Int @default(0)

  // Deduction — snapshot at time of payment
  deduction_rate          Int  // 0, 20, or 30
  deduction_amount_pence  Int  // = labour_amount * (rate/100)
  net_payment_pence       Int  // = gross - deduction

  // CIS period
  payment_date  DateTime // actual date paid — used for tax month grouping
  tax_month     String   // e.g. "2026-05" = 6 May to 5 June period

  description   String?
  notes         String?
  invoice_ref   String? // subcontractor's invoice number

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company       Company       @relation(fields: [company_id], references: [id])
  job           Job?          @relation(fields: [job_id], references: [id], onDelete: SetNull)
  subcontractor Subcontractor @relation(fields: [subcontractor_id], references: [id])

  @@index([company_id])
  @@index([company_id, tax_month])
  @@index([company_id, subcontractor_id])
}

// CIS suffered deductions — CIS deducted FROM this firm by contractors who paid them.
// Net CIS liability = contractor deductions paid out - suffered deductions received.
model CisSufferedDeduction {
  id         String @id @default(cuid())
  company_id String

  // The contractor who paid us (and deducted CIS from us)
  contractor_name    String
  contractor_utr     String?

  // Amounts
  gross_amount_pence      Int  // what they paid us (gross)
  deduction_amount_pence  Int  // CIS they deducted from us
  net_received_pence      Int  // what we actually received = gross - deduction

  // Period — same 6th-5th format as SubcontractorPayment
  payment_date DateTime
  tax_month    String

  invoice_ref String?
  notes       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([company_id, tax_month])
}

model CisMonthlyReturn {
  id         String @id @default(cuid())
  company_id String
  tax_month  String // "2026-05"

  status         String    @default("DRAFT")
  // DRAFT = not yet filed, SUBMITTED = filed with HMRC manually, ACCEPTED = future API
  submitted_at   DateTime?
  submitted_by   String?
  hmrc_reference String?
  notes          String?

  // Snapshot totals at time of submission
  total_gross_pence      Int     @default(0)
  total_deductions_pence Int     @default(0)
  subcontractor_count    Int     @default(0)
  is_nil_return          Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@unique([company_id, tax_month])
  @@index([company_id])
}

// Audit trail — every CIS calculation, export, and submission logged here for HMRC compliance.
model CisAuditLog {
  id         String @id @default(cuid())
  company_id String

  action             String   // CIS300_PDF_GENERATED | CIS300_CSV_EXPORTED | ANNUAL_CSV_EXPORTED | RETURN_SUBMITTED | PDS_GENERATED | PDS_EMAIL_SENT
  tax_month          String?  // e.g. "2026-05"
  tax_year           String?  // e.g. "2025-2026"
  subcontractor_name String?
  subcontractor_id   String?
  performed_by       String   // user name
  details            String?  // extra context (HMRC ref, sub count, etc.)

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([company_id, created_at(sort: Desc)])
}

model GasSafetyCertificate {
  id          String        @id @default(cuid())
  company_id  String
  job_id      String?
  customer_id String?
  engineer_id String?

  cert_type   GasCertType
  status      GasCertStatus @default(DRAFT)
  cert_number String

  inspection_date   DateTime
  property_address  String?
  property_city     String?
  property_postcode String?

  engineer_name   String?
  gas_safe_number String?

  data          Json      @default("{}")
  notes         String?
  next_due_date DateTime?
  last_sent_at  DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  job      Job?      @relation(fields: [job_id], references: [id])
  customer Customer? @relation(fields: [customer_id], references: [id])
  engineer User?     @relation(fields: [engineer_id], references: [id])

  @@unique([company_id, cert_number])
  @@index([company_id])
  @@index([company_id, cert_type])
  @@index([company_id, status])
}

model Timesheet {
  id         String  @id @default(cuid())
  company_id String
  company    Company @relation(fields: [company_id], references: [id])

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  job_id String?
  job    Job?    @relation(fields: [job_id], references: [id])

  date             DateTime
  start_time       DateTime
  finish_time      DateTime

  break_minutes    Int         @default(0)
  duration_minutes Int

  billing_rate      BillingRate @default(STANDARD)
  hourly_rate_pence Int

  total_pence Int

  notes          String?
  is_approved    Boolean   @default(false)
  approved_by_id String?
  approved_by    User?     @relation("TimesheetApprover", fields: [approved_by_id], references: [id])
  approved_at    DateTime?

  clock_in_at       DateTime?
  clock_out_at      DateTime?
  clock_in_lat      Float?
  clock_in_lng      Float?
  clock_in_address  String?
  clock_out_lat     Float?
  clock_out_lng     Float?
  clock_out_address String?
  is_timer_entry    Boolean   @default(false)

  clock_in_flag     String?
  clock_out_flag    String?
  clock_in_reason   String?
  clock_out_reason  String?
  clock_in_note     String?
  clock_out_note    String?
  requires_approval Boolean   @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([company_id])
  @@index([user_id])
  @@index([job_id])
}

model ActiveTimer {
  id         String   @id @default(cuid())
  company_id String
  user_id    String
  job_id     String
  started_at DateTime @default(now())
  lat        Float?
  lng        Float?
  address    String?

  clock_in_flag   String?
  clock_in_reason String?
  clock_in_note   String?

  company Company @relation(fields: [company_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])
  job     Job     @relation(fields: [job_id], references: [id])

  @@unique([user_id, job_id])
  @@index([company_id])
}

model Supplier {
  id             String   @id @default(cuid())
  company_id     String
  name           String
  contact_name   String?
  email          String?
  phone          String?
  mobile         String?
  address_line1  String?
  address_line2  String?
  city           String?
  county         String?
  postcode       String?
  vat_number     String?
  account_number String?
  website        String?
  notes          String?
  is_archived    Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  company        Company         @relation(fields: [company_id], references: [id])
  bills          Bill[]
  purchaseOrders PurchaseOrder[]
  priceListItems PriceListItem[]

  @@index([company_id])
}

model PriceListItem {
  id          String  @id @default(cuid())
  company_id  String
  supplier_id String?

  name        String
  description String?
  item_code   String?
  unit        String?

  cost_price_pence  Int @default(0)
  markup_percent    Int @default(20)
  sell_price_pence  Int @default(0)

  vat_type String @default("STANDARD")
  vat_rate Int    @default(20)

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  supplier Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, supplier_id])
  @@index([company_id, name])
}

model Kit {
  id          String  @id @default(cuid())
  company_id  String
  name        String
  description String?
  items       Json    @default("[]")

  total_cost_pence Int @default(0)
  total_sell_pence Int @default(0)

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Bill {
  id          String   @id @default(cuid())
  company_id  String
  supplier_id String
  created_at  DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  company_id  String
  job_id      String?
  supplier_id String?

  po_number   String
  status      PurchaseOrderStatus @default(DRAFT)

  line_items Json @default("[]")
  // Array of: { description, quantity, unit_cost_pence, total_cost_pence }

  subtotal_pence Int @default(0)
  total_pence    Int @default(0)

  notes         String?
  expected_date DateTime?
  received_date DateTime?
  last_sent_at  DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  job      Job?      @relation(fields: [job_id], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)

  @@unique([company_id, po_number])
  @@index([company_id])
  @@index([company_id, job_id])
}

model Enquiry {
  id           String        @id @default(cuid())
  company_id   String
  company      Company       @relation(fields: [company_id], references: [id])

  enquiry_no   Int

  customer_id    String?
  customer       Customer?   @relation(fields: [customer_id], references: [id])

  assigned_to_id String?
  assigned_to    User?       @relation("EnquiryAssignee", fields: [assigned_to_id], references: [id])

  name          String
  phone         String?
  email         String?

  address_line1 String?
  address_line2 String?
  city          String?
  county        String?
  postcode      String?

  received_date  DateTime      @default(now())
  source         EnquirySource @default(PHONE)
  status         EnquiryStatus @default(NEW)
  intake_method  IntakeMethod  @default(MANUAL)

  notes         String?

  converted_job_id String?   @unique
  converted_at     DateTime?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([company_id, enquiry_no])
  @@index([company_id])
}

model Todo {
  id          String       @id @default(cuid())
  company_id  String
  company     Company      @relation(fields: [company_id], references: [id])

  created_by_id String
  created_by    User       @relation("TodoCreator", fields: [created_by_id], references: [id])

  assigned_to_id String?
  assigned_to    User?     @relation("TodoAssignee", fields: [assigned_to_id], references: [id])

  job_id String?
  job    Job?    @relation(fields: [job_id], references: [id])

  title       String
  description String?
  priority    TodoPriority @default(MEDIUM)
  status      TodoStatus   @default(OPEN)

  due_date   DateTime?
  done_at    DateTime?
  done_by_id String?
  done_by    User?     @relation("TodoCompleter", fields: [done_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([company_id])
  @@index([assigned_to_id])
}

model JobPhoto {
  id         String   @id @default(cuid())
  company_id String
  job_id     String
  user_id    String
  key        String
  url        String
  caption    String?
  phase      String?
  file_size  Int?
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  job     Job     @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id])

  @@index([company_id])
  @@index([job_id])
}

model RecurringJob {
  id          String  @id @default(cuid())
  company_id  String
  customer_id String
  engineer_id String?

  title             String
  description       String?
  schedule_note     String?
  duration_minutes  Int?

  frequency_type  String
  frequency_value Int

  trigger_type  String
  next_run_date DateTime?

  assign_type    String   @default("MANUAL")
  creation_mode  String   @default("ASSIGN")
  scheduled_time String?
  is_active      Boolean  @default(true)
  last_run_at    DateTime?
  jobs_created   Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company  @relation(fields: [company_id], references: [id])
  customer Customer @relation(fields: [customer_id], references: [id])
  engineer User?    @relation(fields: [engineer_id], references: [id])
  jobs     Job[]

  @@index([company_id])
  @@index([company_id, is_active])
}

model JobStage {
  id         String  @id @default(cuid())
  company_id String
  job_id     String
  invoice_id String? @unique

  name        String
  order_index Int

  amount_type  String  // 'PERCENTAGE' | 'FIXED'
  percentage   Float?
  amount_pence Int?

  status String @default("PENDING")
  // 'PENDING' | 'INVOICED' | 'PAID'

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company  @relation(fields: [company_id], references: [id])
  job     Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([job_id])
}

model JobTemplate {
  id          String  @id @default(cuid())
  company_id  String

  name                String
  title               String
  description         String?
  schedule_note       String?
  duration_minutes    Int?
  default_engineer_id String?

  is_active  Boolean @default(true)
  use_count  Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company          Company @relation(fields: [company_id], references: [id])
  default_engineer User?   @relation(fields: [default_engineer_id], references: [id])

  @@index([company_id])
}

model JobServiceReport {
  id          String  @id @default(cuid())
  company_id  String
  job_id      String
  customer_id String?

  report_number String
  status        String @default("DRAFT")

  report_date DateTime @default(now())
  title       String   @default("Job Service Report")

  description String?
  terms       String?

  show_timesheets Boolean @default(true)
  show_certs      Boolean @default(true)
  show_photos     Boolean @default(true)
  show_notes      Boolean @default(true)

  acceptance_token String?  @unique
  accepted_at      DateTime?
  declined_at      DateTime?
  decline_reason   String?

  last_sent_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  job      Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)

  @@unique([company_id, report_number])
  @@index([company_id])
  @@index([job_id])
  @@index([acceptance_token])
}

model CommunicationLog {
  id          String  @id @default(cuid())
  company_id  String
  customer_id String?
  job_id      String?
  invoice_id  String?
  quote_id    String?

  type      String
  subject   String
  to_email  String
  reference String?
  status    String   @default("SENT")
  notes     String?

  sent_at DateTime @default(now())

  company  Company   @relation(fields: [company_id], references: [id])
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  job      Job?      @relation(fields: [job_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, customer_id])
  @@index([company_id, job_id])
  @@index([sent_at])
}
